{
    "version": "0.2.0",
    "configurations": [
        {
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/bk7258/sample_code_oct/bk7258_ap/app.elf",
            "gdbPath": "gdb-multiarch",
            "name": "Debug",
            "request": "attach",
            "type": "cortex-debug",
            "device": "STAR-MC1",
            "interface": "swd",
            "showDevDebugOutput": "raw",
            "servertype": "external",
            "gdbTarget": "127.0.0.1:2331",
            "runToEntryPoint": "main",
            "targetProcessor": 0,
            "numberOfProcessors": 2
        }
    ]
}